{
  "name": "ayustra",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "npx kill-port 4200 && concurrently \"npm run server\" \"ng serve --proxy-config proxy.conf.json\"",
    "start:web": "npx kill-port 4200 && ng serve --proxy-config proxy.conf.json",
    "server": "npx kill-port 4000 && node server/index.js",
    "server:legacy": "node server/consult-server.js",
    "build": "ng build --configuration=production",
    "build:dev": "ng build",
    "watch": "ng build --watch",
    "test": "ng test",
    "lint": "ng lint",
    "docker:build": "docker build -t ayusutra .",
    "docker:run": "docker-compose up -d",
    "docker:stop": "docker-compose down"
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "^17.0.0",
    "@angular/cdk": "^17.0.0",
    "@angular/common": "^17.0.0",
    "@angular/compiler": "^17.0.0",
    "@angular/core": "^17.0.0",
    "@angular/forms": "^17.0.0",
    "@angular/material": "^17.0.0",
    "@angular/platform-browser": "^17.0.0",
    "@angular/platform-browser-dynamic": "^17.0.0",
    "@angular/router": "^17.0.0",
    "@supabase/supabase-js": "^2.99.1",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "multer": "^2.1.1",
    "pdf-parse": "^2.4.5",
    "pdfkit": "^0.17.2",
    "rxjs": "~7.8.0",
    "simple-peer": "^9.11.1",
    "tesseract.js": "^7.0.0",
    "tslib": "^2.3.0",
    "zone.js": "~0.14.0"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "^17.0.0",
    "@angular/cli": "^17.0.0",
    "@angular/compiler-cli": "^17.0.0",
    "@types/jasmine": "~5.1.0",
    "concurrently": "^9.2.1",
    "jasmine-core": "~5.1.0",
    "karma": "~6.4.0",
    "karma-chrome-launcher": "~3.2.0",
    "karma-coverage": "~2.2.0",
    "karma-jasmine": "~5.1.0",
    "karma-jasmine-html-reporter": "~2.1.0",
    "typescript": "~5.2.0"
  }
}
